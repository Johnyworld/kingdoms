; 포커스 테두리는 기본 테마의 사각 아웃라인 대신 비움(픽셀 UI에 이질적).
[sub_resource type="StyleBoxEmpty" id="SBE_focus"]

; 구분선: 체인 브레이드(@3x). 가로 타일링으로 폭에 맞게 반복(스트레치 왜곡 없음).
; 주의: top/bottom margin 12+12 = region 높이 24 → 세로 center 밴드 0px(의도적).
;   Separator 선 두께를 margin 합(24)으로 확보하며, 가로 반복은 margin strip이 담당한다.
;   separation/margin/region 높이를 바꾸면 이 균형이 깨지니 함께 조정할 것.
[sub_resource type="StyleBoxTexture" id="SBT_divider"]
texture = ExtResource("1_sheet")
texture_margin_top = 12.0
texture_margin_bottom = 12.0
region_rect = Rect2(639, 804, 165, 24)
axis_stretch_horizontal = 1
modulate_color = Color(2.6, 2.2, 1.4, 1)

